{
  "name": "ts-api-starter",
  "version": "1.0.0",
  "description": "Bulletproof TypeScript REST API starter",
  "main": "dist/src/index.js",
  "workspaces": [
    "client",
    "shared"
  ],
  "scripts": {
    "dev": "tsx --env-file=.env --watch src/index.ts",
    "dev:client": "npm run dev --prefix client",
    "dev:all": "concurrently \"npm run dev\" \"npm run dev:client\"",
    "build": "tsc",
    "start": "node dist/src/index.js",
    "db:migrate": "node --env-file=.env ./node_modules/.bin/prisma migrate dev",
    "db:generate": "node --env-file=.env ./node_modules/.bin/prisma generate",
    "db:studio": "prisma studio",
    "typecheck": "tsc --noEmit",
    "lint": "biome lint .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "prepare": "husky"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.7.0",
    "@prisma/client": "^7.7.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "express": "^5.2.1",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "passport": "^0.7.0",
    "passport-google-oauth20": "^2.0.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.14.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.19.17",
    "@types/passport": "^1.0.17",
    "@types/passport-google-oauth20": "^2.0.16",
    "@types/passport-jwt": "^4.0.1",
    "@types/pg": "^8.11.11",
    "@types/supertest": "^7.2.0",
    "concurrently": "^9.2.1",
    "husky": "^9.1.7",
    "jest": "^30.3.0",
    "prisma": "^7.7.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.9",
    "tsx": "^4.19.3",
    "typescript": "^5.9.3"
  }
}
